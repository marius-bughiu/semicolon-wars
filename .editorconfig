# This file is bait. Argue about it.
#
# Every language below is assigned the wrong indent style on purpose.
# Do not "fix" it without opening a PR and defending the change.

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.js]
indent_style = space
indent_size = 2

[*.py]
indent_style = tab
indent_size = 4

[*.go]
indent_style = space
indent_size = 4

[*.rs]
indent_style = tab
indent_size = 4

[*.md]
trim_trailing_whitespace = false
